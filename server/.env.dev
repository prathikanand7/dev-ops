# Django core settings
DJANGO_SECRET_KEY=dev-only-secret

# Worker settings required by settings.py
WORKER_CALLBACK_URL=http://localhost:8000/api/jobs/complete/
WORKER_WEBHOOK_SECRET=dev-webhook-secret
WORKER_IMAGE=r-notebook-worker:latest

# Celery/Redis local broker
CELERY_BROKER_URL=redis://localhost:6379/0

# Optional local settings
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# Optional AWS Batch settings (used only when testing AWS Batch endpoints)
AWS_BATCH_JOB_QUEUE=
AWS_BATCH_JOB_DEFINITION=
AWS_BATCH_REGION=us-east-1
