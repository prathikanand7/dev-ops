# Server and Worker ignores
/server/.env
/server/.vscode
server/db.sqlite3
/server/jobs/__pycache__
/worker/outputs
/server/notebook_platform/__pycache__
/server/jobs/migrations/__pycache__
/server/media/*
requests/request.py
server/.env.dev
server/kubeconfig-docker.yaml
/server/k8s-manifests

# Local .terraform directories
**/.terraform/*
/terraform-bootstrap/**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
/terraform-bootstrap/**/*.tfstate
/terraform-bootstrap/**/*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files
secrets.tfvars
secrets.tfvars.json
/terraform-bootstrap/**/*.tfvars
/terraform-bootstrap/**/*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
/terraform-bootstrap/override.tf
/terraform-bootstrap/override.tf.json
/terraform-bootstrap/*_override.tf
/terraform-bootstrap/*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore lock info
.terraform.tfstate.lock.info
/terraform-bootstrap/.terraform.tfstate.lock.info

.idea/
.vscode/settings.json
/terraform/environments/batch-dev/__pycache__
/terraform/environments/batch-dev/test_output_injected_notebook.ipynb

# Ignore Frontend Node Modules
/frontend/node_modules
/server/staticfiles
/server/jobs/tests/__pycache__
*.pyc
server/zappa_settings.json